{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/export/docx.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/export/xlsx.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
